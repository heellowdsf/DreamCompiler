// Data augmentation must (a) synthesize the requested number of rows,
// (b) keep them finite (no garbage/NaN), (c) respect the guard: data at
// or above the threshold is left untouched. Distribution fidelity (that
// synthetic points stay inside the real range) is checked in the interop
// example; here we assert the counts and finiteness.
// EXPECT: AUG_ROWS: PASS
// EXPECT: AUG_GUARD: PASS
// EXPECT: AUG_NAN: PASS
fn app() {
    set_seed(3);
    let X = randn(20, 4);
    let Y = zeros(20, 1);
    let i = 0;
    while (i < 20) { if (i >= 10) { Y[i] = 1.0; } i = i + 1; }

    // augment 20 -> 60
    let XA = augment(X, Y, 100, 60);
    if (augment_count(XA) == 40.0) { println("AUG_ROWS: PASS"); }
    else { print("AUG_ROWS: FAIL "); println(augment_count(XA)); }

    // guard: 20 real rows already >= threshold 10 -> no synthesis
    let XG = augment(X, Y, 10, 60);
    if (augment_count(XG) == 0.0) { println("AUG_GUARD: PASS"); }
    else { print("AUG_GUARD: FAIL "); println(augment_count(XG)); }

    // finiteness
    let s = sum(XA);
    if (s == s) { println("AUG_NAN: PASS"); } else { println("AUG_NAN: FAIL"); }
    return 0.0;
}
