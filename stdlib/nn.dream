fn distillation_loss(student_out, teacher_out, labels, temperature) {
    return distill_loss(student_out, teacher_out, labels, temperature, 0.7);
}

// ============================================================
// CHECKPOINT HELPERS (real-world training resilience)
// ============================================================

// Save complete training state: model params + optimizer + metadata.
// Usage:
//   save_training_state(W1, b1, W2, b2, epoch, current_lr, "ckpt.bin")
fn save_mlp_checkpoint(W1, b1, W2, b2, epoch, lr, path) {
    let id = ckpt_new();
    ckpt_add(id, "W1", W1);
    ckpt_add(id, "b1", b1);
    ckpt_add(id, "W2", W2);
    ckpt_add(id, "b2", b2);
    ckpt_set_meta(id, epoch, 0, lr);
    ckpt_save(id, path);
    return 0.0;
}

// Load training checkpoint. Returns the session id — use ckpt_get(id, name) to extract.
fn load_mlp_checkpoint(path) {
    let id = ckpt_load(path);
    return id;
}

// ============================================================
// NUMERICAL STABILITY HELPERS
// ============================================================

// Safe cross-entropy: log_softmax + nll_loss (the PyTorch F.cross_entropy pattern)
// Much more stable than raw cross_entropy on large logits.
fn safe_cross_entropy(logits, target) {
    let log_probs = log_softmax(logits);
    return nll_loss(log_probs, target);
}

// Check all gradients for NaN/Inf and report if any are bad.
// Call this when training suddenly diverges to find the culprit.
fn check_grad_health(param, param_name) {
    let g = grad(param);
    let bad = has_nan(g);
    return bad;
}
